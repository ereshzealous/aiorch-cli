{
  "paths": [
    {
      "path": "/api/projects",
      "method": "get",
      "summary": "List all projects",
      "parameters": [
        {
          "name": "status",
          "in": "query",
          "description": "Filter by project status (e.g., active)",
          "schema": {
            "type": "string"
          },
          "required": false
        }
      ],
      "responses": {
        "200": {
          "description": "A list of projects."
        }
      }
    },
    {
      "path": "/api/projects",
      "method": "post",
      "summary": "Create a new project",
      "parameters": [],
      "requestBody": {
        "description": "Project details to create",
        "required": true,
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string"
                },
                "owner": {
                  "type": "string"
                },
                "budget": {
                  "type": "number"
                }
              },
              "required": [
                "name",
                "owner",
                "budget"
              ]
            }
          }
        }
      },
      "responses": {
        "201": {
          "description": "Project created successfully."
        }
      }
    },
    {
      "path": "/api/projects/{project_id}",
      "method": "get",
      "summary": "Get a single project by ID",
      "parameters": [
        {
          "name": "project_id",
          "in": "path",
          "description": "ID of the project to retrieve",
          "schema": {
            "type": "integer",
            "format": "int32"
          },
          "required": true
        }
      ],
      "responses": {
        "200": {
          "description": "Project retrieved successfully."
        }
      }
    },
    {
      "path": "/api/projects/{project_id}",
      "method": "patch",
      "summary": "Partially update a project",
      "parameters": [
        {
          "name": "project_id",
          "in": "path",
          "description": "ID of the project to update",
          "schema": {
            "type": "integer",
            "format": "int32"
          },
          "required": true
        }
      ],
      "requestBody": {
        "description": "Fields to update in the project",
        "required": true,
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string"
                },
                "owner": {
                  "type": "string"
                },
                "budget": {
                  "type": "number"
                },
                "status": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "responses": {
        "200": {
          "description": "Project updated successfully."
        }
      }
    },
    {
      "path": "/api/projects/{project_id}",
      "method": "delete",
      "summary": "Soft-delete a project by ID",
      "parameters": [
        {
          "name": "project_id",
          "in": "path",
          "description": "ID of the project to delete",
          "schema": {
            "type": "integer",
            "format": "int32"
          },
          "required": true
        }
      ],
      "responses": {
        "204": {
          "description": "Project soft-deleted successfully."
        }
      }
    },
    {
      "path": "/api/projects/{project_id}/runs",
      "method": "get",
      "summary": "List runs for a project",
      "parameters": [
        {
          "name": "project_id",
          "in": "path",
          "description": "ID of the project",
          "schema": {
            "type": "integer",
            "format": "int32"
          },
          "required": true
        },
        {
          "name": "limit",
          "in": "query",
          "description": "Maximum number of runs to return",
          "schema": {
            "type": "integer",
            "format": "int32",
            "default": 50
          },
          "required": false
        }
      ],
      "responses": {
        "200": {
          "description": "A list of project runs."
        }
      }
    },
    {
      "path": "/api/health",
      "method": "get",
      "summary": "Liveness probe",
      "parameters": [],
      "responses": {
        "200": {
          "description": "Application is healthy."
        }
      }
    }
  ]
}